POSTGRES_USER=pulse
POSTGRES_PASSWORD=pulse
POSTGRES_DB=pulse
POSTGRES_PORT=5432

# Connection string used by the application
PULSE_DB_DSN=postgres://pulse:pulse@localhost:5432/pulse?sslmode=disable

# HTTP server
PULSE_HTTP_ADDR=:8080
PULSE_HTTP_READ_TIMEOUT=5s
PULSE_HTTP_WRITE_TIMEOUT=10s
PULSE_SHUTDOWN_TIMEOUT=15s

# pgx pool
PULSE_DB_MAX_CONNS=20
PULSE_DB_MIN_CONNS=2
PULSE_DB_MAX_CONN_LIFETIME=30m
PULSE_DB_HEALTH_CHECK_PERIOD=30s
